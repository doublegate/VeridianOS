--- VeridianOS musl syscall number remapping patch
---
--- This patch modifies musl's x86_64 syscall_arch.h to remap Linux
--- syscall numbers to VeridianOS equivalents at the __syscall() level.
---
--- musl internally uses Linux x86_64 syscall numbers (e.g. SYS_read=0,
--- SYS_write=1). VeridianOS uses its own numbering (e.g. read=52,
--- write=53). This patch intercepts __syscall() calls and remaps the
--- ~60 syscall numbers that musl actually uses.
---
--- Apply with: cd musl-1.2.5 && patch -p1 < 0001-veridian-syscall-remap.patch

diff --git a/arch/x86_64/syscall_arch.h b/arch/x86_64/syscall_arch.h
--- a/arch/x86_64/syscall_arch.h
+++ b/arch/x86_64/syscall_arch.h
@@ -1,5 +1,99 @@
 #define __SYSCALL_LL_E(x) (x)
 #define __SYSCALL_LL_O(x) (x)

+/* VeridianOS: Remap Linux x86_64 syscall numbers to VeridianOS numbers.
+ *
+ * musl's internal code uses Linux numbers (defined in bits/syscall.h.in).
+ * Rather than patching every call site, we remap at the __syscall level.
+ * Only the ~60 syscalls musl actually uses need remapping.
+ */
+static inline long __veridian_remap_syscall(long nr)
+{
+	switch (nr) {
+	/* Filesystem */
+	case 0:   return 52;   /* read */
+	case 1:   return 53;   /* write */
+	case 2:   return 50;   /* open */
+	case 3:   return 51;   /* close */
+	case 4:   return 150;  /* stat (path-based -> FileStatPath) */
+	case 5:   return 55;   /* fstat (fd-based -> FileStat) */
+	case 6:   return 151;  /* lstat */
+	case 8:   return 54;   /* lseek */
+	case 9:   return 20;   /* mmap */
+	case 10:  return 22;   /* mprotect */
+	case 11:  return 21;   /* munmap */
+	case 12:  return 23;   /* brk */
+	case 16:  return 112;  /* ioctl */
+	case 17:  return 195;  /* pread64 */
+	case 18:  return 196;  /* pwrite64 */
+	case 19:  return 183;  /* readv */
+	case 20:  return 184;  /* writev */
+	case 21:  return 153;  /* access */
+	case 22:  return 65;   /* pipe -> pipe2 */
+	case 32:  return 57;   /* dup */
+	case 33:  return 58;   /* dup2 */
+	case 35:  return 162;  /* nanosleep */
+	case 39:  return 15;   /* getpid */
+	case 41:  return 220;  /* socket */
+	case 42:  return 223;  /* connect */
+	case 43:  return 224;  /* accept */
+	case 44:  return 250;  /* sendto */
+	case 45:  return 251;  /* recvfrom */
+	case 46:  return 338;  /* sendmsg */
+	case 47:  return 339;  /* recvmsg */
+	case 48:  return 227;  /* shutdown */
+	case 49:  return 221;  /* bind */
+	case 50:  return 222;  /* listen */
+	case 51:  return 252;  /* getsockname */
+	case 52:  return 253;  /* getpeername */
+	case 53:  return 228;  /* socketpair */
+	case 54:  return 254;  /* setsockopt */
+	case 55:  return 255;  /* getsockopt */
+	case 56:  return 310;  /* clone */
+	case 57:  return 12;   /* fork */
+	case 59:  return 13;   /* execve */
+	case 60:  return 11;   /* exit */
+	case 61:  return 14;   /* wait4 */
+	case 62:  return 113;  /* kill */
+	case 63:  return 204;  /* uname */
+	case 72:  return 158;  /* fcntl */
+	case 74:  return 73;   /* fsync */
+	case 76:  return 56;   /* ftruncate */
+	case 77:  return 188;  /* truncate */
+	case 79:  return 110;  /* getcwd */
+	case 80:  return 111;  /* chdir */
+	case 82:  return 154;  /* rename */
+	case 83:  return 60;   /* mkdir */
+	case 84:  return 61;   /* rmdir */
+	case 86:  return 155;  /* link */
+	case 87:  return 157;  /* unlink */
+	case 88:  return 156;  /* symlink */
+	case 89:  return 152;  /* readlink */
+	case 90:  return 185;  /* chmod */
+	case 91:  return 186;  /* fchmod */
+	case 92:  return 197;  /* chown */
+	case 93:  return 198;  /* fchown */
+	case 95:  return 187;  /* umask */
+	case 96:  return 163;  /* gettimeofday */
+	case 102: return 170;  /* getuid */
+	case 104: return 172;  /* getgid */
+	case 105: return 174;  /* setuid */
+	case 106: return 175;  /* setgid */
+	case 107: return 171;  /* geteuid */
+	case 108: return 173;  /* getegid */
+	case 109: return 176;  /* setpgid */
+	case 110: return 177;  /* getpgid */
+	case 111: return 178;  /* getpgrp */
+	case 112: return 179;  /* setsid */
+	case 124: return 180;  /* getsid */
+	case 131: return 179;  /* setsid (dup) */
+	case 133: return 199;  /* mknod */
+	case 158: return 203;  /* arch_prctl */
+	case 186: return 43;   /* gettid */
+	case 202: return 311;  /* futex */
+	case 217: return 340;  /* getdents64 */
+	case 228: return 160;  /* clock_gettime */
+	case 229: return 161;  /* clock_getres */
+	case 230: return 162;  /* clock_nanosleep -> nanosleep */
+	case 231: return 11;   /* exit_group -> exit */
+	case 232: return 264;  /* epoll_wait */
+	case 233: return 262;  /* epoll_create1 (via epoll_create) */
+	case 257: return 190;  /* openat */
+	case 258: return 193;  /* mkdirat */
+	case 260: return 191;  /* fstatat */
+	case 263: return 192;  /* unlinkat */
+	case 264: return 194;  /* renameat */
+	case 265: return 348;  /* linkat */
+	case 266: return 349;  /* symlinkat */
+	case 267: return 350;  /* readlinkat */
+	case 268: return 346;  /* fchmodat */
+	case 269: return 347;  /* fchownat */
+	case 281: return 263;  /* epoll_ctl */
+	case 288: return 224;  /* accept4 -> accept */
+	case 289: return 337;  /* signalfd4 */
+	case 290: return 331;  /* eventfd2 */
+	case 291: return 66;   /* dup3 */
+	case 292: return 65;   /* pipe2 */
+	case 293: return 342;  /* inotify_init1 */
+	case 302: return 341;  /* prlimit64 */
+	case 318: return 330;  /* getrandom */
+	case 319: return 351;  /* memfd_create */
+	case 322: return 334;  /* timerfd_create (via 283) */
+	case 325: return 335;  /* timerfd_settime */
+	case 326: return 336;  /* timerfd_gettime */
+	case 7:   return 300;  /* poll */
+	case 13:  return 120;  /* rt_sigaction */
+	case 14:  return 121;  /* rt_sigprocmask */
+	case 15:  return 123;  /* rt_sigreturn */
+	case 127: return 122;  /* rt_sigsuspend */
+	case 28:  return 345;  /* madvise */
+	case 160: return 260;  /* getrlimit */
+	case 161: return 261;  /* setrlimit */
+	case 218: return 352;  /* set_tid_address */
+	case 273: return 353;  /* set_robust_list */
+	default:  return nr;   /* unmapped: kernel returns -ENOSYS */
+	}
+}
+
 static __inline long __syscall0(long n)
 {
+	n = __veridian_remap_syscall(n);
 	unsigned long ret;
@@ -8,6 +103,7 @@

 static __inline long __syscall1(long n, long a1)
 {
+	n = __veridian_remap_syscall(n);
 	unsigned long ret;
 	__asm__ __volatile__ ("syscall" : "=a"(ret) : "a"(n), "D"(a1) : "rcx", "r11", "memory");
 	return ret;
@@ -15,6 +110,7 @@

 static __inline long __syscall2(long n, long a1, long a2)
 {
+	n = __veridian_remap_syscall(n);
 	unsigned long ret;
 	__asm__ __volatile__ ("syscall" : "=a"(ret) : "a"(n), "D"(a1), "S"(a2)
 						  : "rcx", "r11", "memory");
@@ -23,6 +119,7 @@

 static __inline long __syscall3(long n, long a1, long a2, long a3)
 {
+	n = __veridian_remap_syscall(n);
 	unsigned long ret;
 	__asm__ __volatile__ ("syscall" : "=a"(ret) : "a"(n), "D"(a1), "S"(a2),
 						  "d"(a3) : "rcx", "r11", "memory");
@@ -31,6 +128,7 @@

 static __inline long __syscall4(long n, long a1, long a2, long a3, long a4)
 {
+	n = __veridian_remap_syscall(n);
 	unsigned long ret;
 	register long r10 __asm__("r10") = a4;
 	__asm__ __volatile__ ("syscall" : "=a"(ret) : "a"(n), "D"(a1), "S"(a2),
@@ -41,6 +139,7 @@
 static __inline long __syscall5(long n, long a1, long a2, long a3, long a4,
 			long a5)
 {
+	n = __veridian_remap_syscall(n);
 	unsigned long ret;
 	register long r10 __asm__("r10") = a4;
 	register long r8 __asm__("r8") = a5;
@@ -52,6 +151,7 @@
 static __inline long __syscall6(long n, long a1, long a2, long a3, long a4,
 			long a5, long a6)
 {
+	/* VeridianOS mmap packs fd (arg5) and offset (arg6) into a single arg5:
+	 * upper 32 bits = fd, lower 32 bits = offset.
+	 * musl passes them as separate args per Linux ABI, but VeridianOS
+	 * syscall_handler only receives 5 args (arg6 is not forwarded).
+	 * Pack before remapping so the kernel sees the expected format. */
+	if (n == 9) /* mmap */
+		a5 = ((unsigned long)a5 << 32) | ((unsigned long)a6 & 0xFFFFFFFFUL);
+	n = __veridian_remap_syscall(n);
 	unsigned long ret;
 	register long r10 __asm__("r10") = a4;
 	register long r8 __asm__("r8") = a5;
